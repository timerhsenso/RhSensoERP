@model RhSensoERP.Web.Models.Seguranca.Funcao.FuncaoListViewModel
@{
    ViewData["Title"] = Model.PageTitle;
    Layout = "_CrudLayout";
    ViewData["EntityName"] = "Funções do Sistema";
    ViewData["IconClass"] = "fas fa-table";
}

@* ============================================================================
   Permissões injetadas para JavaScript (ANTES do script específico)
   ============================================================================ *@
<script>
    window.crudPermissions = {
        canCreate: @Model.CanCreate.ToString().ToLower(),
        canEdit: @Model.CanEdit.ToString().ToLower(),
        canDelete: @Model.CanDelete.ToString().ToLower(),
        canView: @Model.CanView.ToString().ToLower(),
        actions: "@Model.UserPermissions"
    };
    
    @* v3.4: Configuração para Toggle Ativo *@
    window.crudConfig = {
        hasAtivoField: false,
        entityName: "Funcao",
        pkField: "CdFuncao"
    };
</script>

@* ============================================================================
   Tabela usando partial _CrudTable (toolbar + datatable)
   ============================================================================ *@
@await Html.PartialAsync("_CrudTable", Model)

@* ============================================================================
   Conteúdo do Modal (apenas campos do formulário)
   O wrapper do modal está no _CrudLayout
   ============================================================================ *@
@section ModalContent {
    <input type="hidden" id="Id" name="Id" />
    <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="CdFuncao" class="form-label">
                        Código de Funcao <span class="text-danger">*</span> <span class="badge bg-primary">PK</span>
                    </label>
                    <input type="text" class="form-control" id="CdFuncao" name="CdFuncao" 
                           placeholder="" required  maxlength="30" />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="CdSistema" class="form-label">
                        Código de Sistema <span class="text-danger">*</span> <span class="badge bg-primary">PK</span>
                    </label>
                    <input type="text" class="form-control" id="CdSistema" name="CdSistema" 
                           placeholder="" required  maxlength="10" />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="DcFuncao" class="form-label">
                        Descrição de Funcao
                    </label>
                    <input type="text" class="form-control" id="DcFuncao" name="DcFuncao" 
                           placeholder=""   maxlength="80" />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="DcModulo" class="form-label">
                        Descrição de Modulo
                    </label>
                    <input type="text" class="form-control" id="DcModulo" name="DcModulo" 
                           placeholder=""   maxlength="100" />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="Descricaomodulo" class="form-label">
                        Descricao Modulo
                    </label>
                    <input type="text" class="form-control" id="Descricaomodulo" name="Descricaomodulo" 
                           placeholder=""   maxlength="100" />
                    
                </div>
    </div>

}

@* ============================================================================
   Script específico da entidade
   ============================================================================ *@
@section PageScripts {
    <script src="~/js/seguranca/funcao/funcao.js" asp-append-version="true"></script>
}
