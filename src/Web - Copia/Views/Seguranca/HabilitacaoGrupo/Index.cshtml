@model RhSensoERP.Web.Models.Seguranca.HabilitacaoGrupo.HabilitacaoGrupoListViewModel
@{
    ViewData["Title"] = Model.PageTitle;
    Layout = "_CrudLayout";
    ViewData["EntityName"] = "Habilitação de Grupo";
    ViewData["IconClass"] = "fas fa-table";
}

@* ============================================================================
   Permissões injetadas para JavaScript (ANTES do script específico)
   ============================================================================ *@
<script>
    window.crudPermissions = {
        canCreate: @Model.CanCreate.ToString().ToLower(),
        canEdit: @Model.CanEdit.ToString().ToLower(),
        canDelete: @Model.CanDelete.ToString().ToLower(),
        canView: @Model.CanView.ToString().ToLower(),
        actions: "@Model.UserPermissions"
    };
    
    @* v3.4: Configuração para Toggle Ativo *@
    window.crudConfig = {
        hasAtivoField: false,
        entityName: "HabilitacaoGrupo",
        pkField: "Id"
    };
</script>

@* ============================================================================
   Tabela usando partial _CrudTable (toolbar + datatable)
   ============================================================================ *@
@await Html.PartialAsync("_CrudTable", Model)

@* ============================================================================
   Conteúdo do Modal (apenas campos do formulário)
   O wrapper do modal está no _CrudLayout
   ============================================================================ *@
@section ModalContent {
    <input type="hidden" id="Id" name="Id" />
    <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="CdGrUser" class="form-label">
                        Código de Gr User <span class="text-danger">*</span>
                    </label>
                    <input type="text" class="form-control" id="CdGrUser" name="CdGrUser" 
                           placeholder="" required  maxlength="30" />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="CdFuncao" class="form-label">
                        Código de Funcao <span class="text-danger">*</span>
                    </label>
                    <input type="text" class="form-control" id="CdFuncao" name="CdFuncao" 
                           placeholder="" required  maxlength="30" />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="CdSistema" class="form-label">
                        Código de Sistema
                    </label>
                    <input type="text" class="form-control" id="CdSistema" name="CdSistema" 
                           placeholder=""   maxlength="10" />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="CdAcoes" class="form-label">
                        Código de Acoes <span class="text-danger">*</span>
                    </label>
                    <input type="text" class="form-control" id="CdAcoes" name="CdAcoes" 
                           placeholder="" required  maxlength="20" />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="CdRestric" class="form-label">
                        Código de Restric <span class="text-danger">*</span>
                    </label>
                    <input type="text" class="form-control" id="CdRestric" name="CdRestric" 
                           placeholder="" required  />
                    
                </div>
    </div>

}

@* ============================================================================
   Script específico da entidade
   ============================================================================ *@
@section PageScripts {
    <script src="~/js/seguranca/habilitacaogrupo/habilitacaogrupo.js" asp-append-version="true"></script>
}
