@* =============================================================================
    RHSENSOERP WEB - LAYOUT PRINCIPAL
    =============================================================================
    Arquivo: src/Web/Views/Shared/_Layout.cshtml
    Versão: 3.0 (Sidebar Vertical Colapsável)
    Descrição: Layout moderno com sidebar lateral colapsável, topbar e
               paleta de cores alinhada ao site rhsensoweb.com.br
    ============================================================================= *@

@using RhSensoERP.Web.Services.Menu
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

@{
    var requestToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
    var pageTitle    = ViewData["Title"]?.ToString() ?? "RhSensoERP";
}

<!DOCTYPE html>
<html lang="pt-BR" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="csrf-token" content="@requestToken" />
    <title>@pageTitle - RhSensoERP</title>

    @* ===== FONTES ===== *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />

    @* ===== BOOTSTRAP ===== *@
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    @* ===== FONT AWESOME ===== *@
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    @* ===== DATATABLES ===== *@
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.bootstrap5.min.css" />

    @* ===== SELECT2 ===== *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />

    @* ===== TOASTR ===== *@
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

    @* ===== ESTILOS DO SISTEMA ===== *@
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sidebar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @* Token antiforgery para chamadas AJAX *@
    @Html.AntiForgeryToken()

    @* =====================================================================
       WRAPPER PRINCIPAL
       ===================================================================== *@
    <div class="app-wrapper">

        @* =====================================================================
           SIDEBAR LATERAL
           ===================================================================== *@
        @await Html.PartialAsync("_Sidebar")

        @* ===== OVERLAY MOBILE ===== *@
        <div class="sidebar-overlay" id="sidebarOverlay" aria-hidden="true"></div>

        @* =====================================================================
           ÁREA PRINCIPAL (TOPBAR + CONTEÚDO + FOOTER)
           ===================================================================== *@
        <div class="app-main" id="appMain">

            @* ===== TOPBAR ===== *@
            <header class="app-topbar">

                @* Botão hambúrguer (mobile) *@
                <button class="topbar-sidebar-toggle"
                        id="sidebarMobileToggle"
                        type="button"
                        aria-label="Abrir menu"
                        title="Abrir menu">
                    <i class="fas fa-bars"></i>
                </button>

                @* Título / Breadcrumb *@
                <div class="topbar-breadcrumb d-none d-sm-block">
                    @if (ViewData["BreadcrumbItems"] is IEnumerable<(string Label, string Url)> breadcrumbs && breadcrumbs.Any())
                    {
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb mb-0">
                                <li class="breadcrumb-item">
                                    <a asp-controller="Home" asp-action="Index">
                                        <i class="fas fa-home"></i>
                                    </a>
                                </li>
                                @foreach (var (label, url) in breadcrumbs)
                                {
                                    if (string.IsNullOrEmpty(url))
                                    {
                                        <li class="breadcrumb-item active">@label</li>
                                    }
                                    else
                                    {
                                        <li class="breadcrumb-item"><a href="@url">@label</a></li>
                                    }
                                }
                            </ol>
                        </nav>
                    }
                    else
                    {
                        <span class="topbar-page-title">@pageTitle</span>
                    }
                </div>

                @* Ações da topbar (direita) *@
                <div class="topbar-actions ms-auto">

                    @* Botão de tema (dark/light) *@
                    <button class="topbar-action-btn"
                            id="theme-toggle"
                            type="button"
                            title="Alternar tema">
                        <i class="fas fa-moon"></i>
                    </button>

                    @* Menu do usuário *@
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="dropdown topbar-user-dropdown">
                            <button class="topbar-action-btn dropdown-toggle d-flex align-items-center gap-2"
                                    type="button"
                                    id="topbarUserMenu"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                <div class="topbar-user-avatar">
                                    @(User.Identity.Name?.Substring(0, 1).ToUpper() ?? "U")
                                </div>
                                <span class="d-none d-md-inline small fw-semibold" style="color: var(--text-primary);">
                                    @(User.FindFirst("dcusuario")?.Value ?? User.Identity?.Name)
                                </span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border" aria-labelledby="topbarUserMenu">
                                <li class="px-3 py-2">
                                    <div class="fw-semibold small" style="color: var(--text-primary);">
                                        @(User.FindFirst("dcusuario")?.Value ?? User.Identity?.Name)
                                    </div>
                                    <div class="text-muted" style="font-size: 0.75rem;">
                                        Código: @User.FindFirst("cdusuario")?.Value
                                    </div>
                                </li>
                                <li><hr class="dropdown-divider my-1"></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Dashboard">
                                        <i class="fas fa-id-badge me-2 text-primary"></i>Minha Conta
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider my-1"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="fas fa-sign-out-alt me-2"></i>Sair
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a class="topbar-action-btn" asp-controller="Account" asp-action="Login" title="Entrar">
                            <i class="fas fa-sign-in-alt"></i>
                        </a>
                    }
                </div>
            </header>

            @* ===== CONTEÚDO DAS PÁGINAS ===== *@
            <main class="app-content" role="main">
                @RenderBody()
            </main>

            @* ===== FOOTER ===== *@
<!--//

            <footer class="app-footer">
                
                <span>&copy; @DateTime.Now.Year &mdash; <strong>RhSensoERP</strong></span>
                <span>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy">
                        Privacidade
                    </a>
                </span>
            </footer>
                        //-->
        </div>@* /app-main *@
    </div>@* /app-wrapper *@

    @* =========================================================================
       SCRIPTS - ORDEM IMPORTA!
       ========================================================================= *@

    @* Config global (sem dependências) *@
    <script src="~/js/app-config.js" asp-append-version="true"></script>

    @* Bibliotecas principais *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @* DataTables *@
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/responsive.bootstrap5.min.js"></script>

    @* Select2 *@
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    @* Utilitários *@
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdn.sheetjs.com/xlsx-0.20.1/package/dist/xlsx.full.min.js"></script>

    @* CRUD Base *@
    <script src="~/js/crud-base.js" asp-append-version="true"></script>

    @* Scripts do sistema *@
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/theme-toggle.js" asp-append-version="true"></script>
    <script src="~/js/sidebar.js" asp-append-version="true"></script>

    <script>
        // Configuração global do Toastr
        if (typeof toastr !== 'undefined') {
            toastr.options = {
                closeButton: true,
                progressBar: true,
                positionClass: 'toast-top-right',
                timeOut: 5000,
                extendedTimeOut: 2000
            };
        }

        // Configuração global para requests AJAX com CSRF token
        $(document).ready(function () {
            var token = $('input[name="__RequestVerificationToken"]').val()
                     || $('meta[name="csrf-token"]').attr('content');

            $.ajaxSetup({
                headers: {
                    'RequestVerificationToken': token
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
