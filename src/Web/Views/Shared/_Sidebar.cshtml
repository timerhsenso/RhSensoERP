@* =============================================================================
    RHSENSOERP WEB - SIDEBAR VERTICAL COLAPSÁVEL
    =============================================================================
    Arquivo: src/Web/Views/Shared/_Sidebar.cshtml
    Versão: 2.0 (Sidebar Vertical)
    Descrição: Menu lateral vertical com suporte a colapsar/expandir,
               módulos dinâmicos, favoritos e perfil do usuário.
    ============================================================================= *@

@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<aside class="app-sidebar" id="appSidebar" role="navigation" aria-label="Menu principal">

    @* =====================================================================
       CABEÇALHO - LOGO + BOTÃO DE COLAPSAR
       ===================================================================== *@
    <div class="sidebar-header">
        <a asp-area=""
           asp-controller="Home"
           asp-action="Index"
           class="sidebar-brand"
           title="RhSensoERP - Início">
            <div class="sidebar-brand-icon">
                <i class="fas fa-layer-group"></i>
            </div>
            <span class="sidebar-brand-text">RhSensoERP</span>
        </a>

        @* Botão de colapsar (desktop) *@
        <button class="sidebar-toggle-btn d-none d-lg-flex"
                id="sidebarCollapseBtn"
                type="button"
                title="Recolher menu"
                aria-label="Recolher menu">
            <i class="fas fa-chevron-left"></i>
        </button>
    </div>

    @* =====================================================================
       CORPO - NAVEGAÇÃO
       ===================================================================== *@
    <div class="sidebar-body">
        <ul class="sidebar-nav">

            @* ===== ITEM: DASHBOARD ===== *@
            <li class="sidebar-nav-item">
                <a asp-controller="Home"
                   asp-action="Index"
                   class="sidebar-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")"
                   title="Dashboard">
                    <span class="sidebar-nav-icon">
                        <i class="fas fa-home"></i>
                    </span>
                    <span class="sidebar-nav-text">Dashboard</span>
                </a>
            </li>

            @* ===== MENU DINÂMICO (MÓDULOS DO SISTEMA) ===== *@
            @if (User.Identity?.IsAuthenticated == true)
            {
                <li class="sidebar-nav-item mt-2">
                    <div class="sidebar-section-label">Módulos</div>
                </li>
                @await Component.InvokeAsync("DynamicMenu")
            }

        </ul>
    </div>

    @* =====================================================================
       RODAPÉ - PERFIL DO USUÁRIO
       ===================================================================== *@
    <div class="sidebar-footer">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="dropdown">
                <a href="#"
                   class="sidebar-user-btn dropdown-toggle"
                   id="sidebarUserMenu"
                   data-bs-toggle="dropdown"
                   aria-expanded="false"
                   title="@User.Identity.Name">
                    <div class="sidebar-user-avatar">
                        @(User.Identity.Name?.Substring(0, 1).ToUpper() ?? "U")
                    </div>
                    <div class="sidebar-user-info">
                        <span class="sidebar-user-name">@User.Identity.Name</span>
                        <span class="sidebar-user-code">Cód: @User.FindFirst("cdusuario")?.Value</span>
                    </div>
                </a>

                <ul class="dropdown-menu dropdown-menu-dark shadow border-0 mb-1"
                    aria-labelledby="sidebarUserMenu"
                    style="min-width: 200px;">
                    <li>
                        <a class="dropdown-item" asp-controller="Account" asp-action="Dashboard">
                            <i class="fas fa-id-badge me-2"></i>Minha Conta
                        </a>
                    </li>
                    <li><hr class="dropdown-divider border-secondary"></li>
                    <li>
                        <button type="button"
                                class="dropdown-item d-flex align-items-center justify-content-between"
                                id="theme-toggle-sidebar">
                            <span><i class="fas fa-adjust me-2"></i>Tema</span>
                            <i class="fas fa-moon" id="theme-icon-sidebar"></i>
                        </button>
                    </li>
                    <li><hr class="dropdown-divider border-secondary"></li>
                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="dropdown-item text-danger">
                                <i class="fas fa-sign-out-alt me-2"></i>Sair
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        }
        else
        {
            <a asp-controller="Account"
               asp-action="Login"
               class="sidebar-nav-link"
               title="Entrar">
                <span class="sidebar-nav-icon">
                    <i class="fas fa-sign-in-alt"></i>
                </span>
                <span class="sidebar-nav-text">Entrar</span>
            </a>
        }
    </div>

</aside>
