@* =============================================================================
    RHSENSOERP WEB - DYNAMIC MENU VIEW (SIDEBAR VERTICAL)
    =============================================================================
    Arquivo: src/Web/Views/Shared/Components/DynamicMenu/Default.cshtml
    Versão: 2.0 (Sidebar Vertical com Accordion)
    Descrição: Renderiza o menu dinâmico na sidebar lateral com suporte a
               accordion (submenu colapsável), favoritos e item ativo.
    ============================================================================= *@

@model IReadOnlyList<RhSensoERP.Web.Services.Menu.MenuModuleViewModel>

@{
    var currentArea = ViewContext.RouteData.Values["area"]?.ToString();
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    var favorites = Model
        .SelectMany(m => m.Items)
        .Where(i => i.IsFavorite && i.HasPermission)
        .ToList();
}

@* ================== SEÇÃO DE FAVORITOS ================== *@
@if (favorites.Any())
{
    <li class="sidebar-nav-item">
        <div class="sidebar-section-label">
            <i class="fas fa-star me-1 text-warning" style="font-size: 0.6rem;"></i>
            Favoritos
        </div>
    </li>

    @foreach (var fav in favorites.Take(8))
    {
        var isFavActive =
            string.Equals(fav.Controller, currentController, StringComparison.OrdinalIgnoreCase)
            && string.Equals(fav.Area ?? string.Empty, currentArea ?? string.Empty, StringComparison.OrdinalIgnoreCase)
            && string.Equals(fav.Action, currentAction, StringComparison.OrdinalIgnoreCase);

        <li class="sidebar-nav-item">
            <a href="@fav.Url"
               class="sidebar-nav-link @(isFavActive ? "active" : "")"
               title="@fav.Description">
                <span class="sidebar-nav-icon">
                    <i class="@fav.Icon"></i>
                </span>
                <span class="sidebar-nav-text">@fav.DisplayName</span>
            </a>
        </li>
    }

    <li class="sidebar-nav-item">
        <hr style="border-color: var(--sidebar-border); margin: 0.5rem 1rem;" />
    </li>
}

@* ================== MÓDULOS DO MENU ================== *@
@foreach (var module in Model)
{
    var moduleId = "submenu-" + module.Module.ToString().ToLower().Replace("_", "-");

    var isModuleActive = module.Items.Any(i =>
        string.Equals(i.Controller, currentController, StringComparison.OrdinalIgnoreCase)
        && string.Equals(i.Area ?? string.Empty, currentArea ?? string.Empty, StringComparison.OrdinalIgnoreCase));

    <li class="sidebar-nav-item">
        <button type="button"
                class="sidebar-nav-link @(isModuleActive ? "active" : "")"
                data-sidebar-submenu="@moduleId"
                aria-expanded="@(isModuleActive ? "true" : "false")"
                aria-controls="@moduleId"
                title="@module.DisplayName">
            <span class="sidebar-nav-icon">
                <i class="@module.Icon"></i>
            </span>
            <span class="sidebar-nav-text">@module.DisplayName</span>
            <i class="fas fa-chevron-right sidebar-nav-arrow"></i>
        </button>

        <ul class="sidebar-submenu collapse @(isModuleActive ? "show" : "")"
            id="@moduleId">
            @foreach (var item in module.Items)
            {
                var isActive =
                string.Equals(item.Controller, currentController, StringComparison.OrdinalIgnoreCase)
                && string.Equals(item.Area ?? string.Empty, currentArea ?? string.Empty, StringComparison.OrdinalIgnoreCase)
                && string.Equals(item.Action, currentAction, StringComparison.OrdinalIgnoreCase);

                <li class="sidebar-submenu-item">
                    @if (item.ComingSoon || !item.HasPermission)
                    {
                        <span class="sidebar-submenu-link"
                              style="opacity: 0.45; cursor: default;"
                              title="@(item.ComingSoon ? "Em desenvolvimento" : "Sem permissão")">
                            <span class="sidebar-submenu-icon">
                                <i class="@item.Icon"></i>
                            </span>
                            <span class="sidebar-submenu-text">
                                @item.DisplayName
                                @if (!string.IsNullOrEmpty(item.Badge))
                                {
                                    <span class="badge bg-@item.BadgeColor ms-1" style="font-size: 0.65rem;">@item.Badge</span>
                                }
                            </span>
                        </span>
                    }
                    else
                    {
                        <a href="@item.Url"
                           class="sidebar-submenu-link @(isActive ? "active" : "")"
                           title="@item.Description">
                            <span class="sidebar-submenu-icon">
                                <i class="@item.Icon"></i>
                            </span>
                            <span class="sidebar-submenu-text">
                                @item.DisplayName
                                @if (!string.IsNullOrEmpty(item.Badge))
                                {
                                    <span class="badge bg-@item.BadgeColor ms-1" style="font-size: 0.65rem;">@item.Badge</span>
                                }
                            </span>
                            <button type="button"
                                    class="sidebar-submenu-favorite favorite-toggle"
                                    data-screen-key="@item.ScreenKey"
                                    data-cd-sistema="@item.CdSistema"
                                    data-cd-funcao="@item.CdFuncao"
                                    data-area="@item.Area"
                                    data-controller="@item.Controller"
                                    data-action="@item.Action"
                                    data-display-name="@item.DisplayName"
                                    data-icon="@item.Icon"
                                    title="@(item.IsFavorite ? "Remover dos favoritos" : "Adicionar aos favoritos")"
                                    onclick="event.preventDefault(); event.stopPropagation();">
                                <i class="@(item.IsFavorite ? "fas" : "far") fa-star @(item.IsFavorite ? "text-warning" : "")"></i>
                            </button>
                        </a>
                    }
                </li>
            }
        </ul>
    </li>
}

@* ================== SCRIPT DE TOGGLE FAVORITOS ================== *@
<script>
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.favorite-toggle').forEach(function (btn) {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();

                const button = this;
                const icon   = button.querySelector('i');

                const data = {
                    screenKey:   button.dataset.screenKey,
                    cdSistema:   button.dataset.cdSistema   || null,
                    cdFuncao:    button.dataset.cdFuncao    || null,
                    area:        button.dataset.area        || null,
                    controller:  button.dataset.controller  || null,
                    action:      button.dataset.action      || null,
                    displayName: button.dataset.displayName || null,
                    icon:        button.dataset.icon        || null
                };

                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value
                           || document.querySelector('meta[name="csrf-token"]')?.content;

                fetch('/api/favorites/toggle', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token || ''
                    },
                    body: JSON.stringify(data)
                })
                .then(r => r.json())
                .then(result => {
                    if (result.isFavorite !== undefined) {
                        icon.classList.toggle('fas',          result.isFavorite);
                        icon.classList.toggle('far',         !result.isFavorite);
                        icon.classList.toggle('text-warning', result.isFavorite);

                        button.title = result.isFavorite
                            ? 'Remover dos favoritos'
                            : 'Adicionar aos favoritos';

                        if (typeof toastr !== 'undefined') {
                            toastr.success(result.isFavorite
                                ? 'Adicionado aos favoritos!'
                                : 'Removido dos favoritos');
                        }
                    }
                })
                .catch(() => {
                    if (typeof toastr !== 'undefined') {
                        toastr.error('Erro ao atualizar favorito');
                    }
                });
            });
        });
    });
</script>
