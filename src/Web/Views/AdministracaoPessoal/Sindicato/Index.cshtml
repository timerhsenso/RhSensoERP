@model RhSensoERP.Web.Models.AdministracaoPessoal.Sindicato.SindicatoListViewModel
@{
    ViewData["Title"] = Model.PageTitle;
    Layout = "_CrudLayout";
    ViewData["EntityName"] = "Sindicato";
    ViewData["IconClass"] = "fas fa-table";
}

@* ============================================================================
   Permissões injetadas para JavaScript (ANTES do script específico)
   ============================================================================ *@
<script>
    window.crudPermissions = {
        canCreate: @Model.CanCreate.ToString().ToLower(),
        canEdit: @Model.CanEdit.ToString().ToLower(),
        canDelete: @Model.CanDelete.ToString().ToLower(),
        canView: @Model.CanView.ToString().ToLower(),
        actions: "@Model.UserPermissions"
    };
    
    @* v3.4: Configuração para Toggle Ativo *@
    window.crudConfig = {
        hasAtivoField: false,
        entityName: "Sindicato",
        pkField: "Id"
    };
</script>

@* ============================================================================
   Tabela usando partial _CrudTable (toolbar + datatable)
   ============================================================================ *@
@await Html.PartialAsync("_CrudTable", Model)

@* ============================================================================
   Conteúdo do Modal (apenas campos do formulário)
   O wrapper do modal está no _CrudLayout
   ============================================================================ *@
@section ModalContent {
    <input type="hidden" id="Id" name="Id" />
    <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="Cdsindicat" class="form-label">
                        Código
                    </label>
                    <input type="text" class="form-control" id="Cdsindicat" name="Cdsindicat" 
                           placeholder=""   maxlength="2" />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="Dcsindicat" class="form-label">
                        Descrição
                    </label>
                    <input type="text" class="form-control" id="Dcsindicat" name="Dcsindicat" 
                           placeholder=""   maxlength="40" />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="Dcendereco" class="form-label">
                        Endereço
                    </label>
                    <input type="text" class="form-control" id="Dcendereco" name="Dcendereco" 
                           placeholder=""   maxlength="30" />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="Cgcsindicat" class="form-label">
                        CNPJ
                    </label>
                    <input type="text" class="form-control" id="Cgcsindicat" name="Cgcsindicat" 
                           placeholder=""   maxlength="14" />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="CdentIdade" class="form-label">
                        Código Entidade
                    </label>
                    <input type="text" class="form-control" id="CdentIdade" name="CdentIdade" 
                           placeholder=""   maxlength="20" />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="Fltipo" class="form-label">
                        Tipo
                    </label>
                    <input type="text" class="form-control" id="Fltipo" name="Fltipo" 
                           placeholder=""   />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="Cdtabbase" class="form-label">
                        Tabela Base
                    </label>
                    <input type="text" class="form-control" id="Cdtabbase" name="Cdtabbase" 
                           placeholder=""   maxlength="3" />
                    
                </div>
    </div>

}

@* ============================================================================
   Script específico da entidade
   ============================================================================ *@
@section PageScripts {
    <script src="~/js/administracaopessoal/sindicato/sindicato.js" asp-append-version="true"></script>
}
