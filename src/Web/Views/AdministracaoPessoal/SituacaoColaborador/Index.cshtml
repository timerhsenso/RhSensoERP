@model RhSensoERP.Web.Models.AdministracaoPessoal.SituacaoColaborador.SituacaoColaboradorListViewModel
@{
    ViewData["Title"] = Model.PageTitle;
    Layout = "_CrudLayout";
    ViewData["EntityName"] = "Situação do Colaborador";
    ViewData["IconClass"] = "fas fa-table";
}

@* ============================================================================
   Permissões injetadas para JavaScript (ANTES do script específico)
   ============================================================================ *@
<script>
    window.crudPermissions = {
        canCreate: @Model.CanCreate.ToString().ToLower(),
        canEdit: @Model.CanEdit.ToString().ToLower(),
        canDelete: @Model.CanDelete.ToString().ToLower(),
        canView: @Model.CanView.ToString().ToLower(),
        actions: "@Model.UserPermissions"
    };
    
    @* v3.4: Configuração para Toggle Ativo *@
    window.crudConfig = {
        hasAtivoField: false,
        entityName: "SituacaoColaborador",
        pkField: "Id"
    };
</script>

@* ============================================================================
   Tabela usando partial _CrudTable (toolbar + datatable)
   ============================================================================ *@
@await Html.PartialAsync("_CrudTable", Model)

@* ============================================================================
   Conteúdo do Modal (apenas campos do formulário)
   O wrapper do modal está no _CrudLayout
   ============================================================================ *@
@section ModalContent {
    <input type="hidden" id="Id" name="Id" />
    <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="Cdsituacao" class="form-label">
                        Código
                    </label>
                    <input type="text" class="form-control" id="Cdsituacao" name="Cdsituacao" 
                           placeholder=""   maxlength="2" />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="Dcsituacao" class="form-label">
                        Descrição
                    </label>
                    <input type="text" class="form-control" id="Dcsituacao" name="Dcsituacao" 
                           placeholder=""   maxlength="40" />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="Fldemissao" class="form-label">
                        É Demissão
                    </label>
                    <input type="text" class="form-control" id="Fldemissao" name="Fldemissao" 
                           placeholder=""   maxlength="1" />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="FlafaStame" class="form-label">
                        É Afastamento
                    </label>
                    <input type="text" class="form-control" id="FlafaStame" name="FlafaStame" 
                           placeholder=""   maxlength="1" />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="Qtdiasbene" class="form-label">
                        Dias Benefício
                    </label>
                    <input type="text" class="form-control" id="Qtdiasbene" name="Qtdiasbene" 
                           placeholder=""   />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="Qtdiasprev" class="form-label">
                        Dias Previdência
                    </label>
                    <input type="text" class="form-control" id="Qtdiasprev" name="Qtdiasprev" 
                           placeholder=""   />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="Cdfgts" class="form-label">
                        Código FGTS
                    </label>
                    <input type="text" class="form-control" id="Cdfgts" name="Cdfgts" 
                           placeholder=""   maxlength="1" />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="Cdsefip" class="form-label">
                        Código SEFIP
                    </label>
                    <input type="text" class="form-control" id="Cdsefip" name="Cdsefip" 
                           placeholder=""   maxlength="1" />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="Cdsefip2" class="form-label">
                        Código SEFIP 2
                    </label>
                    <input type="text" class="form-control" id="Cdsefip2" name="Cdsefip2" 
                           placeholder=""   maxlength="2" />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="Flpferias" class="form-label">
                        Perde Férias
                    </label>
                    <input type="text" class="form-control" id="Flpferias" name="Flpferias" 
                           placeholder=""   maxlength="1" />
                    
                </div>
    </div>

}

@* ============================================================================
   Script específico da entidade
   ============================================================================ *@
@section PageScripts {
    <script src="~/js/administracaopessoal/situacaocolaborador/situacaocolaborador.js" asp-append-version="true"></script>
}
