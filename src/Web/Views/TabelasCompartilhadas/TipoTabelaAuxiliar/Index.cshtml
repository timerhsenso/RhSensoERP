@model RhSensoERP.Web.Models.TabelasCompartilhadas.TipoTabelaAuxiliar.TipoTabelaAuxiliarListViewModel
@{
    ViewData["Title"] = Model.PageTitle;
    Layout = "_CrudLayout";
    ViewData["EntityName"] = "Tabela Auxiliar";
    ViewData["IconClass"] = "fas fa-table";
}

@* ============================================================================
   Permissões injetadas para JavaScript (ANTES do script específico)
   ============================================================================ *@
<script>
    window.crudPermissions = {
        canCreate: @Model.CanCreate.ToString().ToLower(),
        canEdit: @Model.CanEdit.ToString().ToLower(),
        canDelete: @Model.CanDelete.ToString().ToLower(),
        canView: @Model.CanView.ToString().ToLower(),
        actions: "@Model.UserPermissions"
    };
    
    @* v3.4: Configuração para Toggle Ativo *@
    window.crudConfig = {
        hasAtivoField: false,
        entityName: "TipoTabelaAuxiliar",
        pkField: "CdTpTabela"
    };
</script>

@* ============================================================================
   Tabela usando partial _CrudTable (toolbar + datatable)
   ============================================================================ *@
@await Html.PartialAsync("_CrudTable", Model)

@* ============================================================================
   Conteúdo do Modal (apenas campos do formulário)
   O wrapper do modal está no _CrudLayout
   ============================================================================ *@
@section ModalContent {
    <input type="hidden" id="Id" name="Id" />
    <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="CdTpTabela" class="form-label">
                        Código de Tp Tabela <span class="text-danger">*</span> <span class="badge bg-primary">PK</span>
                    </label>
                    <input type="text" class="form-control" id="CdTpTabela" name="CdTpTabela" 
                           placeholder="" required  maxlength="2" />
                    
                </div>
                <div class="col-md-6 mb-3">
                    <label for="DcTabela" class="form-label">
                        Descrição de Tabela <span class="text-danger">*</span>
                    </label>
                    <input type="text" class="form-control" id="DcTabela" name="DcTabela" 
                           placeholder="" required  maxlength="60" />
                    
                </div>
    </div>

}

@* ============================================================================
   Script específico da entidade
   ============================================================================ *@
@section PageScripts {
    <script src="~/js/tabelascompartilhadas/tipotabelaauxiliar/tipotabelaauxiliar.js" asp-append-version="true"></script>
}
